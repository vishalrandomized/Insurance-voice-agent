# Web
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SALES_DEMO_PASSWORD=demo-sales

# API
FRONTEND_ORIGIN=http://localhost:3000

# Provider selection for the live stack
# Keep these values if you are using Gemini + AssemblyAI + Deepgram.
LLM_PROVIDER=gemini
STT_PROVIDER=assemblyai
TTS_PROVIDER=deepgram
EMBEDDING_PROVIDER=gemini

# Paste your API keys on the right-hand side of the "="
# Example:
# GEMINI_API_KEY=AIza...
# ASSEMBLYAI_API_KEY=123456...
# DEEPGRAM_API_KEY=abcd1234...

# REQUIRED for your chosen stack
GEMINI_API_KEY=
ASSEMBLYAI_API_KEY=
DEEPGRAM_API_KEY=

# Model names for your chosen stack
LLM_MODEL=gemini-2.0-flash
STT_MODEL=u3-rt-pro
TTS_MODEL=aura-2-thalia-en
EMBEDDING_MODEL=gemini-embedding-2

# Optional OpenAI fallback; leave empty unless you want OpenAI available too.
OPENAI_API_KEY=

DATABASE_URL=
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
DEFAULT_PRODUCT_ID=
DEFAULT_DOCUMENT_ID=
MAX_PDF_SIZE_MB=20
MAX_PDF_PAGES=250
